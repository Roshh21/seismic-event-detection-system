```gitignore
# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Mac / Linux system files
.DS_Store
Thumbs.db

# VS Code
.vscode/

# PyCharm
.idea/

# Model checkpoints
checkpoints/*.pt
checkpoints/*.pth
checkpoints/*.ckpt

# Output predictions and generated results
outputs/
outputs_indian_test/

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Dataset files (large raw seismic data)
data/raw/noise/
data/raw/stead/chunk2/
data/raw/stead/chunk4/
*.hdf5
*.csv
*.npz
*.npy

# Test outputs
test_results/
evaluation_results/

# OS generated files
Desktop.ini

# Environment variables
.env

# Build files
build/
dist/
*.egg-info/

# Coverage reports
.coverage
htmlcov/

# Backup files
*.bak
*.swp
```
